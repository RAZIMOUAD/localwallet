<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="org.example.controllers.WalletConfirmationController">
    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Portefeuille Créé !" />
    <Label fx:id="walletAddressLabel" text="Adresse : Chargement..." />
    <Label fx:id="walletBalanceLabel" text="Solde : Chargement..." />
    <Label fx:id="seedPhraseLabel" text="Phrase secrète : Chargement..." />
    <Label fx:id="filePathLabel" text="Chemin du fichier : Chargement..." />
    <Button onAction="#copySeedPhrase" text="Copier la phrase secrète" />

    <Button onAction="#closeAndRedirectToLogin" text="Fermer" />
    <Label fx:id="feedbackText" style="-fx-text-fill: green;" text="Feedback : Chargement..." />

</VBox>
